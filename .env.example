# Next.js
# Canonical public site URL used for metadata, hreflang, robots, sitemap,
# webhooks, and absolute links.
# Production MUST be the final HTTPS domain, for example https://elreda.com.
# Do not leave localhost, Vercel preview URLs, or staging URLs here unless that
# URL is intentionally the public launch domain.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Sanity
# Public Sanity project ID for published content.
NEXT_PUBLIC_SANITY_PROJECT_ID=
# Public Sanity dataset. Use "development" locally and on Vercel preview.
# Vercel Production MUST use "production".
NEXT_PUBLIC_SANITY_DATASET=development
# Public Sanity API version used by Sanity clients.
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Server-only viewer token for draft preview and production content checks.
# Never expose this with NEXT_PUBLIC_ and never use a write/admin token here.
SANITY_API_READ_TOKEN=
# Server-only HMAC secret for Sanity ISR webhook verification.
SANITY_WEBHOOK_SECRET=

# Email
# Server-only Resend API key for transactional form emails.
# Leave empty only when launch uses the documented manual Supabase monitoring workflow.
RESEND_API_KEY=

# Uploadthing
# Server-only Uploadthing v7 token for file upload handling.
UPLOADTHING_TOKEN=

# Supabase
# Public Supabase project URL for browser-safe clients.
NEXT_PUBLIC_SUPABASE_URL=
# Public Supabase anonymous key for browser-safe clients.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only Supabase service role key for form persistence.
# Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Bot protection
# Public Cloudflare Turnstile site key rendered in forms.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server-only Cloudflare Turnstile secret key for token verification.
TURNSTILE_SECRET_KEY=
# Upstash Redis REST URL for form rate limiting.
UPSTASH_REDIS_REST_URL=
# Server-only Upstash Redis REST token for form rate limiting.
UPSTASH_REDIS_REST_TOKEN=

# Consent
# Public CookieYes website key. Loads https://cdn-cookieyes.com/client_data/<key>/script.js.
# Required in production before analytics is enabled.
NEXT_PUBLIC_COOKIEYES_WEBSITE_KEY=

# Analytics
# Public Google Tag Manager container ID. CookieYes controls consent.
NEXT_PUBLIC_GTM_ID=
# Public GA4 measurement ID. CookieYes controls consent.
NEXT_PUBLIC_GA4_ID=

# Monitoring
# Browser-safe Sentry DSN for JavaScript error capture.
NEXT_PUBLIC_SENTRY_DSN=
# Server-side Sentry DSN for route handlers, Server Actions, and server rendering.
SENTRY_DSN=
# Sentry organization slug for source map upload during production builds.
SENTRY_ORG=
# Sentry project slug for source map upload during production builds.
SENTRY_PROJECT=
# Server-only Sentry auth token for source map upload during production builds.
SENTRY_AUTH_TOKEN=
# Optional Sentry environment override. Vercel also provides VERCEL_ENV.
SENTRY_ENVIRONMENT=

# Development flags
# Keep analytics disabled locally and on preview. Set to "false" in production
# only after CookieYes, GTM, and GA4 consent behavior is verified.
DISABLE_ANALYTICS=true
# Controlled Lenis activation. Production must remain false unless smooth
# scrolling has separately passed accessibility and device QA.
NEXT_PUBLIC_ENABLE_SMOOTH_SCROLL=false

# QA
# Optional Playwright target for preview/production verification. This is not
# consumed by the app runtime and should point at the deployment under test.
PLAYWRIGHT_BASE_URL=
